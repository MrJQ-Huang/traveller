{
  "name": "changshu-map-planner-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "data:convert": "node scripts/convert-csv-to-places.mjs",
    "prebuild": "npm run data:convert",
    "dev": "vite --host 0.0.0.0",
    "agent:llm": "node scripts/xiaochang-llm-server.mjs",
    "dev:data": "npm run data:convert && vite --host 0.0.0.0",
    "dev:llm": "vite --host 0.0.0.0 --host 127.0.0.1 --port 5173",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.16",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.2"
  }
}
