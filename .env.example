# AMap
VITE_AMAP_KEY=your_amap_web_key
VITE_AMAP_SECURITY_CODE=your_amap_security_code
VITE_AMAP_STYLE=amap://styles/normal

# Xiaochang Agent provider
# mock: frontend local rule brain
# ccswitch: Xiaochang adapter / CCswitch bridge, POST /agent/chat
# backend: formal backend, POST /api/agent/chat
VITE_AGENT_PROVIDER=ccswitch
VITE_CCSWITCH_BASE_URL=http://127.0.0.1:8787
VITE_CCSWITCH_AGENT_PATH=/agent/chat
# VITE_AGENT_PROVIDER=backend
# VITE_AGENT_BACKEND_BASE_URL=http://127.0.0.1:8787
# VITE_AGENT_BACKEND_PATH=/api/agent/chat

# Xiaochang adapter. It talks to CCswitch/OpenAI-compatible API or
# Anthropic-compatible config from ~/.claude/settings.json, then converts
# model output into Xiaochang Agent JSON.
XIAOCHANG_AGENT_HOST=127.0.0.1
XIAOCHANG_AGENT_PORT=8787
CCSWITCH_API_BASE_URL=http://127.0.0.1:your_ccswitch_port/v1
CCSWITCH_API_KEY=
CCSWITCH_MODEL=your_ccswitch_model_name

# Optional Anthropic-compatible settings. Usually not needed when CC Switch
# has already written ANTHROPIC_BASE_URL / ANTHROPIC_AUTH_TOKEN into
# ~/.claude/settings.json.
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your_token
# ANTHROPIC_MODEL=MiniMax-M2.7

# Fallback OpenAI-compatible settings.
# Do not expose these values to frontend code.
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_llm_api_key
# LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.35
LLM_REQUEST_TIMEOUT_MS=60000
